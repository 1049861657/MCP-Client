{
  "name": "mcp-client",
  "version": "1.0.0",
  "description": "Model Context Protocol客户端 - 工具调用演示",
  "type": "module",
  "main": "dist/app.js",
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && prisma generate && tsc",
